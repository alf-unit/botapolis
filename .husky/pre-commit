#!/usr/bin/env sh
# ============================================================================
# Botapolis · pre-commit hook
# ----------------------------------------------------------------------------
# One job: gate staged MDX through content-validator.ts. Type-agnostic — any
# file under content/*/{en,ru}/**/*.mdx is checked, no whitelist.
#
# Translation (звено 2): producing RU twins is owned by Claude Code in the
# same session as the EN write — NOT a hook. The validator's pairing pass
# surfaces missing RU twins (WARNING by default; ERROR with --strict-pairing
# once backfill is done).
#
# History note: pre-2026-06-03 this hook auto-translated EN→RU via OpenRouter
# (Haiku). That path is removed — operator decision, Haiku out.
# ============================================================================
set -e

# Any staged MDX under content/*/en|ru/.../*.mdx. Universal glob — new
# content types are picked up automatically with no hook edits.
staged_mdx=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '^content/[^/]+/(en|ru)/.*\.mdx$' \
  || true)

if [ -z "$staged_mdx" ]; then
  # No MDX in this commit — exit fast.
  exit 0
fi

echo ""
echo "[pre-commit] validating staged MDX (schema + safety + fence + pairing):"
echo "$staged_mdx" | sed 's/^/  /'

if ! npm run --silent validate:content -- $staged_mdx; then
  echo ""
  echo "[pre-commit] content validation failed — commit aborted"
  exit 1
fi

echo "[pre-commit] content validation passed"
echo ""

exit 0

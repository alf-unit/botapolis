# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Block D — .env.example IS checked in as the onboarding template. Without
# this negation .env* above would exclude it too.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Local Claude Code harness state — never commit
.claude/

# Pagefind static search index — regenerated on every build, ~700KB of
# Rust-compiled WASM + JSON. The build script scripts/build-search-index.ts
# rebuilds this at deploy time; commit it and we'd merge-conflict on every PR.
/public/pagefind/

  "verification_protocol": [
    "1. Curl the url with -I and check 200 + content-type contains 'xml' or 'rss'.",
    "2. Open in a feed reader (e.g. feedly) and confirm recent items render.",
    "3. Flip tracked=true and let SCOUT pick it up on next 4-hour cycle.",
    "4. If 404 or empty: search '<vendor> blog rss' / '<vendor> feed' — many vendors hide the URL one click deeper than the blog index."
  ],

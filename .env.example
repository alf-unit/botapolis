# ============================================================================
# Botapolis · .env.example — template for local development
# ----------------------------------------------------------------------------
# Copy to .env.local and fill in real values; `.env.local` is gitignored.
# Production / preview values live in Vercel's encrypted env store —
# `npx vercel env ls` to see what's already wired up there.
#
# Anything prefixed NEXT_PUBLIC_ ships to the browser bundle. Treat anything
# else as a server-only secret.
# ============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Auth + Postgres. Get from Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side bypass — never ship to the client. Used by service.ts helpers
# (sitemap, /api/* writes) and cron jobs.
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Optional in dev — limiters degrade to allow-always when these are unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI · OpenRouter (block A migration) ─────────────────────────────────────
# Drives /api/tools/description. OPENROUTER_MODEL defaults to
# anthropic/claude-haiku-4.5 — override only if you want to A/B-test
# a different model (no code change needed).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# ── Newsletter · Beehiiv ────────────────────────────────────────────────────
# Optional — without these, /api/newsletter still validates the email and
# writes the subscriber row to Supabase, just doesn't forward to Beehiiv.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ── Transactional email · Resend (block F) ──────────────────────────────────
# Drives /api/newsletter (welcome email) + /api/contact (inbox notification
# + auto-reply). Every helper in lib/email/resend.ts no-ops when the key
# is unset, so omitting this in dev / preview is fine.
RESEND_API_KEY=
# Defaults to "Botapolis <editorial@botapolis.com>". Override if your
# verified Resend sender uses a different display address.
RESEND_FROM_ADDRESS=
# Where /api/contact submissions are forwarded. Defaults to
# editorial@botapolis.com.
RESEND_ADMIN_INBOX=

# ── Anti-bot · Cloudflare Turnstile (block D) ──────────────────────────────
# Newsletter + Contact forms render the widget when SITE_KEY is present,
# server endpoints enforce the gate when SECRET is present. Set both or
# neither — half-configured = always-blocked-or-always-open.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Analytics ───────────────────────────────────────────────────────────────
# Plausible script is injected only when ENABLED is the literal string "true".
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=botapolis.com
NEXT_PUBLIC_PLAUSIBLE_ENABLED=true
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Site basics ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://botapolis.com
# Webhook-signed token Supabase posts to /api/revalidate. Generate via:
#   openssl rand -hex 32
REVALIDATE_SECRET=

# ── Vercel cron auth (auto-provisioned on Vercel) ──────────────────────────
# Vercel sets CRON_SECRET automatically for projects with vercel.json crons.
# Only set this locally if you want to curl-test the /api/cron/* endpoints
# with an explicit Bearer header.
CRON_SECRET=

# ── Local dev escape hatches ───────────────────────────────────────────────
# Skip the @t3-oss/env-nextjs schema validation on boot. Use when you're
# intentionally running with a sparse .env.local (e.g. just typechecking
# a branch). Never set in production.
# SKIP_ENV_VALIDATION=1
